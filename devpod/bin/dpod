#!/bin/bash
set -e

if [ -f /.dockerenv ] || [ -f /run/.containerenv ] || [ -n "$DEVCONTAINER" ]; then
  echo "Error: dpod must be run on the host machine, not inside a container"
  exit 1
fi

WORKSPACE_ID="${DEVPOD_WORKSPACE_ID:-dev-workspace}"
DEVCONTAINER_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/devpod-workspace/devcontainer.json"
DOTFILES_URL="${DEVPOD_DOTFILES_URL:-https://github.com/laat/dotfiles}"
IDE="${DEVPOD_IDE:-none}"

if [ -z "$DEVPOD_SERVICE_ACCOUNT" ]; then
  echo "Error: DEVPOD_SERVICE_ACCOUNT is not set" >&2
  echo "Set it to your GCP service account email, e.g.:" >&2
  echo "  export DEVPOD_SERVICE_ACCOUNT=devpod@my-project.iam.gserviceaccount.com" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  echo "Usage: dpod <command> [flags]"
  echo ""
  echo "Commands:"
  echo "  up        Create or start workspace"
  echo "  ssh       SSH into workspace"
  echo "  recreate  Rebuild from scratch"
  echo "  stop      Stop workspace"
  echo "  delete    Remove workspace"
  echo "  status    Show workspace status"
  exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
  up)
    if devpod list 2>/dev/null | grep -q "^$WORKSPACE_ID"; then
      devpod up --devcontainer-path "$DEVCONTAINER_PATH" "$WORKSPACE_ID" "$@"
    else
      devpod up "$HOME/code" \
        --devcontainer-path "$DEVCONTAINER_PATH" \
        --dotfiles "$DOTFILES_URL" \
        --id "$WORKSPACE_ID" \
        --ide "$IDE" \
        --provider-option "SERVICE_ACCOUNT=$DEVPOD_SERVICE_ACCOUNT" \
        "$@"
    fi
    ;;
  recreate)
    devpod up "$WORKSPACE_ID" \
      --devcontainer-path "$DEVCONTAINER_PATH" \
      --dotfiles "$DOTFILES_URL" \
      --provider-option "SERVICE_ACCOUNT=$DEVPOD_SERVICE_ACCOUNT" \
      --recreate "$@"
    ;;
  ssh)
    ssh "$WORKSPACE_ID.devpod" "$@"
    ;;
  stop)
    devpod stop "$WORKSPACE_ID" "$@"
    ;;
  delete)
    devpod delete "$WORKSPACE_ID" "$@"
    ;;
  status)
    devpod list | grep -E "^NAME|^$WORKSPACE_ID" || echo "Workspace not found"
    ;;
  *)
    echo "Unknown command: $COMMAND"
    exit 1
    ;;
esac
