#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage: cs-tmux <command> [args]

Commands:
  list                 List codespaces for pickers
  preview <name>       Show codespace details
  connect <name>       SSH to the codespace and attach/create remote tmux
  ssh <name> <session> SSH to the codespace and attach/create remote tmux
EOF
}

sanitize_tmux_name() {
  printf '%s' "$1" | tr -cs '[:alnum:]_.-' '-'
}

codespace_repo() {
  gh codespace view -c "$1" --json repository --template '{{.repository}}'
}

repo_basename() {
  basename "$1"
}

list_codespaces() {
  gh codespace list \
    --limit "${CS_TMUX_LIMIT:-50}" \
    --json name,displayName,repository,state,lastUsedAt,machineName \
    --template '{{range .}}{{.name}}{{"\t"}}{{.repository}}{{"\t"}}{{.state}}{{"\t"}}{{.displayName}}{{"\t"}}{{.machineName}}{{"\t"}}{{.lastUsedAt}}{{"\n"}}{{end}}'
}

preview_codespace() {
  codespace="$1"
  remote_session="$(remote_session_name "$codespace")"

  gh codespace view -c "$codespace"
  printf '\n'
  printf 'Remote tmux session: %s\n' "$remote_session"
  printf 'Enter: SSH into Codespace and attach/create remote tmux\n'
}

remote_session_name() {
  repo="$(codespace_repo "$1")"
  sanitize_tmux_name "$(repo_basename "$repo")"
}

connect_codespace() {
  codespace="$1"
  remote_session="$(remote_session_name "$codespace")"

  ssh_codespace "$codespace" "$remote_session"
}

ssh_codespace() {
  codespace="$1"
  remote_session="$2"

  # Use a remote tmux session so work survives laptop sleep or tunnel drops.
  # Override TERM: xterm-ghostty is not in the remote terminfo, use xterm-256color.
  exec gh codespace ssh -c "$codespace" -- -t env TERM=xterm-256color tmux new-session -A -s "$remote_session"
}

command="${1:-}"
case "$command" in
  list)
    list_codespaces
    ;;
  preview)
    [ "$#" -eq 2 ] || { usage >&2; exit 2; }
    preview_codespace "$2"
    ;;
  connect)
    [ "$#" -eq 2 ] || { usage >&2; exit 2; }
    connect_codespace "$2"
    ;;
  ssh)
    [ "$#" -eq 3 ] || { usage >&2; exit 2; }
    ssh_codespace "$2" "$3"
    ;;
  -h | --help | help | '')
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
