#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage: cs-tmux <command> [args]

Commands:
  list                 List codespaces for pickers
  preview <name>       Show codespace details
  connect <name>       Switch to a local tmux session backed by the codespace
  ssh <name> <session> SSH to the codespace and attach/create remote tmux
EOF
}

sanitize_tmux_name() {
  printf '%s' "$1" | tr -cs '[:alnum:]_.-' '-'
}

codespace_repo() {
  gh codespace view -c "$1" --json repository --template '{{.repository}}'
}

codespace_display_name() {
  gh codespace view -c "$1" --json displayName --template '{{.displayName}}'
}

repo_basename() {
  basename "$1"
}

list_codespaces() {
  gh codespace list \
    --limit "${CS_TMUX_LIMIT:-50}" \
    --json name,displayName,repository,state,lastUsedAt,machineName \
    --template '{{range .}}{{.name}}{{"\t"}}{{.repository}}{{"\t"}}{{.state}}{{"\t"}}{{.displayName}}{{"\t"}}{{.machineName}}{{"\t"}}{{.lastUsedAt}}{{"\n"}}{{end}}'
}

preview_codespace() {
  codespace="$1"
  local_session="$(local_session_name "$codespace")"

  gh codespace view -c "$codespace"
  printf '\n'
  if tmux has-session -t "$local_session" 2>/dev/null; then
    printf 'Local tmux session: %s (running)\n' "$local_session"
  else
    printf 'Local tmux session: %s (not running)\n' "$local_session"
  fi
  printf 'Enter: connect via local tmux + remote tmux\n'
}

local_session_name() {
  codespace="$1"
  repo="$(codespace_repo "$codespace")"
  display_name="$(codespace_display_name "$codespace")"
  repo_name="$(repo_basename "$repo")"

  sanitize_tmux_name "cs-${repo_name}-${display_name}"
}

remote_session_name() {
  repo="$(codespace_repo "$1")"
  sanitize_tmux_name "$(repo_basename "$repo")"
}

connect_codespace() {
  codespace="$1"
  local_session="$(local_session_name "$codespace")"
  remote_session="$(remote_session_name "$codespace")"
  script_path="$(command -v cs-tmux || printf '%s' "$0")"

  if ! tmux has-session -t "$local_session" 2>/dev/null; then
    tmux new-session -d -s "$local_session" "$script_path ssh $codespace $remote_session"
    tmux set-option -t "$local_session" @codespace_name "$codespace" >/dev/null
    tmux set-option -t "$local_session" @codespace_remote_session "$remote_session" >/dev/null
  fi

  if ! tmux has-session -t "$local_session" 2>/dev/null; then
    echo "failed to create local tmux session: $local_session" >&2
    exit 1
  fi

  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$local_session"
  else
    tmux attach-session -t "$local_session"
  fi
}

ssh_codespace() {
  codespace="$1"
  remote_session="$2"

  # Use a remote tmux session so work survives laptop sleep or tunnel drops.
  exec gh codespace ssh -c "$codespace" -- -t tmux new-session -A -s "$remote_session"
}

command="${1:-}"
case "$command" in
  list)
    list_codespaces
    ;;
  preview)
    [ "$#" -eq 2 ] || { usage >&2; exit 2; }
    preview_codespace "$2"
    ;;
  connect)
    [ "$#" -eq 2 ] || { usage >&2; exit 2; }
    connect_codespace "$2"
    ;;
  ssh)
    [ "$#" -eq 3 ] || { usage >&2; exit 2; }
    ssh_codespace "$2" "$3"
    ;;
  -h | --help | help | '')
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
