font-family = JetBrainsMono Nerd Font
font-size = 14

theme = Catppuccin Mocha

background-opacity = 1
unfocused-split-opacity = 1

window-padding-x = 4
window-padding-y = 4

cursor-style = block
cursor-style-blink = false

copy-on-select = clipboard
mouse-hide-while-typing = true
focus-follows-mouse = true

window-decoration = true
macos-titlebar-style = hidden
macos-option-as-alt = left

keybind = super+k=text:\x01t
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
keybind = super+alt+h=goto_split:left
keybind = super+alt+l=goto_split:right
keybind = super+alt+k=goto_split:top
keybind = super+alt+j=goto_split:bottom
