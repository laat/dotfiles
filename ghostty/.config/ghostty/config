font-family = JetBrainsMono Nerd Font
font-size = 14

theme = Catppuccin Mocha

background-opacity = 1
unfocused-split-opacity = 1

window-padding-x = 4
window-padding-y = 4

cursor-style = block
cursor-style-blink = false

copy-on-select = clipboard
mouse-hide-while-typing = true
focus-follows-mouse = true

window-decoration = true
macos-titlebar-style = hidden
macos-option-as-alt = left

keybind = super+b=text:\x02
keybind = super+p=text:\x02t
keybind = super+t=text:\x02c
keybind = super+shift+t=new_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = super+6=goto_tab:6
keybind = super+7=goto_tab:7
keybind = super+8=goto_tab:8
keybind = super+9=goto_tab:9
keybind = super+0=goto_tab:10
keybind = super+ctrl+1=text:\x1b1
keybind = super+ctrl+2=text:\x1b2
keybind = super+ctrl+3=text:\x1b3
keybind = super+ctrl+4=text:\x1b4
keybind = super+ctrl+5=text:\x1b5
keybind = super+ctrl+6=text:\x1b6
keybind = super+ctrl+7=text:\x1b7
keybind = super+ctrl+8=text:\x1b8
keybind = super+ctrl+9=text:\x1b9
keybind = super+ctrl+0=text:\x1b0
keybind = super+h=text:\x02h
keybind = super+j=text:\x02j
keybind = super+l=text:\x02l
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
