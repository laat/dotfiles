font-family = JetBrainsMono Nerd Font
font-size = 14

theme = Catppuccin Mocha

background-opacity = 1
unfocused-split-opacity = 1

window-padding-x = 4
window-padding-y = 4

cursor-style = block
cursor-style-blink = false

copy-on-select = clipboard
mouse-hide-while-typing = true
focus-follows-mouse = true

window-decoration = true
macos-titlebar-style = hidden
macos-option-as-alt = left

keybind = super+b=text:\x02
keybind = super+p=text:\x02t
keybind = super+t=text:\x02c
keybind = super+shift+t=new_tab
# Unbind ghostty defaults to allow tmux window switching
keybind = super+0=unbind
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind
keybind = super+9=unbind
keybind = super+1=text:\u{2}1
keybind = super+2=text:\u{2}2
keybind = super+3=text:\u{2}3
keybind = super+4=text:\u{2}4
keybind = super+5=text:\u{2}5
keybind = super+6=text:\u{2}6
keybind = super+7=text:\u{2}7
keybind = super+8=text:\u{2}8
keybind = super+9=text:\u{2}9
keybind = super+0=text:\u{2}0
keybind = super+shift+1=goto_tab:1
keybind = super+shift+2=goto_tab:2
keybind = super+shift+3=goto_tab:3
keybind = super+shift+4=goto_tab:4
keybind = super+shift+5=goto_tab:5
keybind = super+shift+6=goto_tab:6
keybind = super+shift+7=goto_tab:7
keybind = super+shift+8=goto_tab:8
keybind = super+shift+9=goto_tab:9
keybind = super+shift+0=goto_tab:10
keybind = super+h=text:\x02h
keybind = super+j=text:\x02j
keybind = super+l=text:\x02l
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
