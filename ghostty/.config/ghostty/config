font-family = JetBrainsMono Nerd Font
font-size = 14

theme = Catppuccin Mocha

background-opacity = 1
unfocused-split-opacity = 1

window-padding-x = 4
window-padding-y = 4

cursor-style = block
cursor-style-blink = false

copy-on-select = clipboard
mouse-hide-while-typing = true
focus-follows-mouse = true

window-decoration = true
macos-titlebar-style = hidden
macos-option-as-alt = left

keybind = super+b=text:\x02
keybind = super+p=text:\x02t
keybind = super+t=text:\x02c
keybind = super+digit_1=unbind
keybind = super+1=text:\x1b1
keybind = super+digit_2=unbind
keybind = super+2=text:\x1b2
keybind = super+digit_3=unbind
keybind = super+3=text:\x1b3
keybind = super+digit_4=unbind
keybind = super+4=text:\x1b4
keybind = super+digit_5=unbind
keybind = super+5=text:\x1b5
keybind = super+digit_6=unbind
keybind = super+6=text:\x1b6
keybind = super+digit_7=unbind
keybind = super+7=text:\x1b7
keybind = super+digit_8=unbind
keybind = super+8=text:\x1b8
keybind = super+digit_9=unbind
keybind = super+9=text:\x1b9
keybind = super+digit_0=unbind
keybind = super+0=text:\x1b0
keybind = super+h=text:\x1bh
keybind = super+j=text:\x1bj
keybind = super+k=text:\x1bk
keybind = super+l=text:\x1bl
keybind = super+shift+h=text:\x1bH
keybind = super+shift+j=text:\x1bJ
keybind = super+shift+k=text:\x1bK
keybind = super+shift+l=text:\x1bL
keybind = super+ctrl+h=text:\x02H
keybind = super+ctrl+j=text:\x02J
keybind = super+ctrl+k=text:\x02K
keybind = super+ctrl+l=text:\x02L
keybind = super+d=text:\x02|
keybind = super+shift+d=text:\x02-
keybind = super+shift+enter=new_split:right
keybind = super+shift+minus=new_split:down
