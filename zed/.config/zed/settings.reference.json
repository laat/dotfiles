// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "copilot",
  },
  "buffer_font_features": {
    "liga": false,
    "calt": false,
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "agent": {
    "default_model": {
      "provider": "opus 4.6",
      "model": "vertex_ai/claude-opus-4-6",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "openai_compatible": {
      "opus 4.6": {
        "api_url": "YOUR_LITELLM_URL_HERE",
        "available_models": [
          {
            "name": "vertex_ai/claude-opus-4-6",
            "max_tokens": 200000,
            "max_output_tokens": 128000,
            "max_completion_tokens": 128000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "terminal": {
    "copy_on_select": true,
    "max_scroll_history_lines": 15000,
  },
  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
  },
  "cursor_shape": "bar",
  "autosave": "on_focus_change",
  "file_types": {
    "clojure": ["*.lisp"],
    "toml": ["*.toml"],
    "jsonc": ["*.json"],
  },
  "linked_edits": true,
  "show_whitespaces": "all",
  "show_edit_predictions": true,
  "semantic_tokens": "off",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [80],
  "soft_wrap": "none",
  "hard_tabs": false,
  "tab_size": 2,
  "vim_mode": true,
  "icon_theme": "Catppuccin Frappé",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
}
